    {
      "parameters": {
        "method": "POST",
        "url": "https://discord.com/api/webhooks/",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"username\": \"🤖 Agent Logger\",\n  \"embeds\": [{\n    \"title\": \"❌ Erreur Agent : {{ $('Normalize Log Entry').item.json.workflow_name }}\",\n    \"description\": \"```{{ $('Normalize Log Entry').item.json.error_message }}```\",\n    \"color\": 15158332,\n    \"fields\": [\n      { \"name\": \"Execution ID\", \"value\": \"{{ $('Normalize Log Entry').item.json.execution_id }}\", \"inline\": true },\n      { \"name\": \"Durée\", \"value\": \"{{ $('Normalize Log Entry').item.json.duration_ms }} ms\", \"inline\": true }\n    ],\n    \"timestamp\": \"{{ $('Normalize Log Entry').item.json.timestamp }}\"\n  }]\n}",
        "options": {}
